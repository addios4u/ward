# ================================================================
# Ward 공통 환경변수 설정
# 이 파일을 복사해서 .env 로 사용하세요: cp .env.sample .env
# ================================================================

# ----------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=ward
POSTGRES_USER=ward
POSTGRES_PASSWORD=your_password_here
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ----------------------------------------------------------------
# Redis
# ----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ----------------------------------------------------------------
# Server (ward-server)
# ----------------------------------------------------------------
SERVER_PORT=4000
SERVER_HOST=0.0.0.0

# 세션 인증 (프로덕션에서는 반드시 강력한 시크릿으로 변경)
SESSION_SECRET=your_session_secret_here_change_this

# 초기 관리자 계정 (첫 실행 시 자동 생성)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password_here

# 데이터 보존 기간 (일)
METRICS_RETENTION_DAYS=30
LOGS_RETENTION_DAYS=7

# ----------------------------------------------------------------
# Web (ward-web)
# ----------------------------------------------------------------
WEB_PORT=3000

# ----------------------------------------------------------------
# Agent (ward-agent)
# ----------------------------------------------------------------
# 에이전트가 데이터를 전송할 서버 URL
AGENT_SERVER_URL=http://localhost:4000
# 메트릭 수집 주기 (초)
AGENT_METRICS_INTERVAL=10
# Heartbeat 주기 (초)
AGENT_HEARTBEAT_INTERVAL=30
