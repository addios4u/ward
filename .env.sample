# ================================================================
# Ward 공통 환경변수 설정
# 이 파일을 복사해서 .env 로 사용하세요: cp .env.sample .env
# ================================================================

# ----------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=ward
POSTGRES_USER=ward
POSTGRES_PASSWORD=your_password_here
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ----------------------------------------------------------------
# Redis
# ----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ----------------------------------------------------------------
# Server (ward-server)
# ----------------------------------------------------------------
SERVER_PORT=4000
SERVER_HOST=0.0.0.0

# JWT 인증
JWT_SECRET=your_jwt_secret_here_change_this
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# 데이터 보존 기간 (일)
METRICS_RETENTION_DAYS=30
LOGS_RETENTION_DAYS=7

# ----------------------------------------------------------------
# Web (ward-web)
# ----------------------------------------------------------------
WEB_PORT=3000
# 브라우저에서 접근하는 서버 URL
NEXT_PUBLIC_SERVER_URL=http://localhost:4000
# 서버사이드에서 접근하는 서버 URL (Docker 내부 통신)
INTERNAL_SERVER_URL=http://server:4000

# ----------------------------------------------------------------
# Agent (ward-agent)
# ----------------------------------------------------------------
# 에이전트가 데이터를 전송할 서버 URL
AGENT_SERVER_URL=http://localhost:4000
# 메트릭 수집 주기 (초)
AGENT_METRICS_INTERVAL=10
# Heartbeat 주기 (초)
AGENT_HEARTBEAT_INTERVAL=30
