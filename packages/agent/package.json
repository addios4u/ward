{
  "name": "@ward/agent",
  "version": "0.1.0",
  "private": true,
  "description": "Ward 서버 모니터링 에이전트",
  "main": "dist/index.js",
  "bin": {
    "ward": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:monitor": "tsx watch src/start-dev.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:self": "node dist/start-self.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.1",
    "pidusage": "^4.0.1",
    "systeminformation": "^5.31.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "@types/pidusage": "^2.0.5",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.21.0",
    "vitest": "^2.1.9"
  }
}
