# TimescaleDB를 베이스로 사용 (PostgreSQL 16 포함)
# - timescaledb: 시계열 데이터 최적화 (metrics, logs, processes 테이블)
# - pgvector: 벡터 검색 (로그 의미 검색 등 향후 활용)
# - 한국어 로케일: UTF-8 정렬/비교 지원
FROM timescale/timescaledb:latest-pg16

# timescale/timescaledb:latest-pg16 이미지에 pgvector 포함됨 - 별도 설치 불필요

# 한국어 UTF-8 환경변수 설정 (Alpine/musl은 locale-gen 불필요)
ENV LANG=ko_KR.UTF-8 \
    LANGUAGE=ko_KR:ko \
    LC_ALL=ko_KR.UTF-8
